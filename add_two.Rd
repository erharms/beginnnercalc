\name{add_two}
\alias{add_two}
\title{Add two numbers}
\usage{
add_two(x, y)
}
\arguments{
\item{x}{A single numeric value.}

\item{y}{A single numeric value.}
}
\value{
A numeric value: \code{x + y}.
}
\description{
Adds \code{x} and \code{y}.
}
\examples{
